   "source": [
    "accounts = [\n",
    "    (101, \"Chennai\", 50000),\n",
    "    (102, \"Mumbai\", 70000),\n",
    "    (103, \"Chennai\", 30000),\n",
    "    (104, \"Delhi\", 40000)\n",
    "]\n",
    "\n",
    "df = spark.createDataFrame(\n",
    "    accounts,\n",
    "    [\"account_id\", \"city\", \"balance\"]\n",
    ")\n",
    "\n",
    "report = df.groupBy(\"city\").sum(\"balance\")\n",
    "\n",
    "display(report)"
   ]
  },
